generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["audit", "budget", "cost", "delivery", "inventory", "public"]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Realm {
  id               String     @id @default(cuid())
  realmId          String     @unique @map("realm_id")
  name             String
  accessToken      String?    @map("access_token")
  refreshToken     String?    @map("refresh_token")
  expiresAt        DateTime?  @map("expires_at")
  refreshExpiresAt DateTime?  @map("refresh_expires_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  locations        Location[]

  @@map("realms")
  @@schema("public")
}

model Location {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  classId        String?  @map("class_id")
  realmId        String   @map("realm_id")
  startYearMonth String?  @map("start_year_month")
  showBudget     Boolean  @default(true) @map("show_budget")
  budgets        Budget[]
  realm          Realm    @relation(fields: [realmId], references: [id])
  users          User[]

  @@map("locations")
  @@schema("public")
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?        @map("email_verified")
  image          String?
  role           UserRole?        @default(manager)
  status         UserStatus       @default(pending_onboarding) @map("status")
  locationId     String?          @map("location_id")
  permittedById  String?          @map("permitted_by_id")
  permittedAt    DateTime?        @map("permitted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  rejectReason   String?          @map("reject_reason")
  budgetSettings BudgetSettings[] @relation("BudgetSettingsUpdatedBy")
  accounts       Account[]
  sessions       Session[]
  location       Location?        @relation(fields: [locationId], references: [id])
  permittedBy    User?            @relation("UserPermittedBy", fields: [permittedById], references: [id])
  permittedUsers User[]           @relation("UserPermittedBy")

  @@map("users")
  @@schema("public")
}

enum UserRole {
  admin
  office
  manager

  @@schema("public")
}

enum UserStatus {
  pending_onboarding
  pending_approval
  active
  rejected

  @@schema("public")
}

// ===============================
// BUDGET
// ===============================
model BudgetSettings {
  id                    String   @id @default(cuid())
  budgetRate            Decimal  @map("budget_rate") @db.Decimal(5, 4)
  referencePeriodMonths Int      @map("reference_period_months")
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedById           String?  @map("updated_by_id")
  updatedBy             User?    @relation("BudgetSettingsUpdatedBy", fields: [updatedById], references: [id])

  @@map("budget_settings")
  @@schema("budget")
}

model Budget {
  id                        String   @id @default(cuid())
  locationId                String   @map("location_id")
  yearMonth                 String   @map("year_month")
  totalAmount               Decimal  @map("total_amount") @db.Decimal(14, 2)
  createdAt                 DateTime @default(now()) @map("created_at")
  budgetRateUsed            Decimal? @map("budget_rate_used") @db.Decimal(5, 4)
  referencePeriodMonthsUsed Int?     @map("reference_period_months_used")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  error                     String?  @map("error")
  location                  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, yearMonth])
  @@map("budgets")
  @@schema("budget")
}
